#!/bin/bash
set -euo pipefail

DRY_RUN="${DRY_RUN:-0}"

# Source common libs
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/logging"
source "$SCRIPT_DIR/lib/os"

detect_os() {
    case "$(uname -s)" in
        Linux*)
            if [ -f /etc/arch-release ]; then
                echo "arch"
            elif [ -f /etc/debian_version ]; then
                echo "debian"
            else
                echo "linux"
            fi
            ;;
        Darwin*)
            echo "macos"
            ;;
        *)
            echo "unknown"
            ;;
    esac
}

clone_os_repo() {
    local os="$1"
    local dotfiles_dir="$HOME/dotfiles"
    local os_repo=""
    local branch=""
    local include_gaming="${DOTFILES_INCLUDE_GAMING:-0}"

    case "$os" in
        arch)
            os_repo="https://github.com/stivce-devops-dude/dotfiles-arch.git"
            branch="${DOTFILES_BRANCH:-minimal}"
            ;;
        macos)
            os_repo="https://github.com/stivce-devops-dude/dotfiles-mac.git"
            branch="${DOTFILES_BRANCH:-main}"
            ;;
        *)
            echo "Unknown OS, skipping OS-specific repo clone"
            return 0
            ;;
    esac

    local target_dir="${dotfiles_dir}-${os}"

    if [ -d "$target_dir" ]; then
        echo "OS-specific repo already exists at $target_dir"
    else
        echo "Cloning $os specific repo (branch: $branch) to $target_dir..."
        if [ "$DRY_RUN" = "1" ]; then
            echo "  [DRY-RUN] Would run: git clone -b $branch --depth 1 $os_repo $target_dir"
        else
            git clone -b "$branch" --depth 1 "$os_repo" "$target_dir"
        fi
    fi

    if [ "$include_gaming" = "1" ] && [ "$os" = "arch" ]; then
        echo "Applying gaming branch on top..."
        if [ "$DRY_RUN" = "1" ]; then
            echo "  [DRY-RUN] Would fetch and apply gaming branch"
        else
            git -C "$target_dir" fetch origin gaming
            git -C "$target_dir" checkout gaming -- .
            git -C "$target_dir" add -A
            git -C "$target_dir" commit -m "Apply gaming additions" || true
        fi
    fi

    echo "Applying OS-specific configs from $target_dir..."
    echo "  Running: yadm alt --global $target_dir/"
    if [ "$DRY_RUN" = "1" ]; then
        echo "  [DRY-RUN] Would run: yadm alt --global $target_dir/"
    else
        yadm alt --global "$target_dir/"
    fi
    echo "  yadm alt done"

    # Copy root-level files (like .Brewfile, .zshrc) to home
    if [ -d "$target_dir" ]; then
        echo "Copying additional OS-specific files..."
        if [ "$DRY_RUN" = "1" ]; then
            [ -f "$target_dir/.Brewfile" ] && echo "  [DRY-RUN] Would copy .Brewfile"
            [ -f "$target_dir/.zshrc" ] && echo "  [DRY-RUN] Would copy .zshrc"
            [ -f "$target_dir/.gitconfig" ] && echo "  [DRY-RUN] Would copy .gitconfig"
        else
            cp "$target_dir/.Brewfile" "$HOME/.Brewfile" 2>/dev/null || true
            cp "$target_dir/.zshrc" "$HOME/.zshrc" 2>/dev/null || true
            cp "$target_dir/.gitconfig" "$HOME/.gitconfig" 2>/dev/null || true
        fi
    fi

    # Run OS-specific bootstrap if available
    local os_bootstrap="$target_dir/.config/yadm/bootstrap"
    if [ -f "$os_bootstrap" ]; then
        echo "Running OS-specific bootstrap from $os_bootstrap..."
        if [ "$DRY_RUN" = "1" ]; then
            echo "  [DRY-RUN] Would run: bash $os_bootstrap"
        else
            bash "$os_bootstrap"
        fi
    else
        echo "No OS-specific bootstrap found at $os_bootstrap"
    fi
}

main() {
    local os
    os=$(detect_os)
    echo "Detected OS: $os"
    
    local default_branch="main"
    [ "$os" = "arch" ] && default_branch="minimal"
    echo "Branch: ${DOTFILES_BRANCH:-$default_branch}, Gaming: ${DOTFILES_INCLUDE_GAMING:-0}"

    clone_os_repo "$os"
}

main "$@"
