#!/bin/bash
set -euo pipefail

# Source common libs
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/logging"
source "$SCRIPT_DIR/lib/os"

detect_os() {
    case "$(uname -s)" in
        Linux*)
            if [ -f /etc/arch-release ]; then
                echo "arch"
            elif [ -f /etc/debian_version ]; then
                echo "debian"
            else
                echo "linux"
            fi
            ;;
        Darwin*)
            echo "macos"
            ;;
        *)
            echo "unknown"
            ;;
    esac
}

clone_os_repo() {
    local os="$1"
    local dotfiles_dir="$HOME/dotfiles"
    local os_repo=""
    local branch=""
    local include_gaming="${DOTFILES_INCLUDE_GAMING:-0}"

    case "$os" in
        arch)
            os_repo="https://github.com/stivce-devops-dude/dotfiles-arch.git"
            branch="${DOTFILES_BRANCH:-minimal}"
            ;;
        macos)
            os_repo="https://github.com/stivce-devops-dude/dotfiles-mac.git"
            branch="${DOTFILES_BRANCH:-main}"
            ;;
        *)
            echo "Unknown OS, skipping OS-specific repo clone"
            return 0
            ;;
    esac

    local target_dir="${dotfiles_dir}-${os}"

    # Force HTTPS for GitHub URLs and disable credential helper
    git config --global url."https://github.com/".insteadOf "git@github.com:"
    git config --global url."https://github.com/".insteadOf "ssh://git@github.com/"
    git config --global credential.helper ""
    unset GIT_SSH_COMMAND
    export GIT_TERMINAL_PROMPT=0

    if [ -d "$target_dir" ]; then
        echo "OS-specific repo already exists at $target_dir"
    else
        echo "Cloning $os specific repo (branch: $branch) to $target_dir..."
        git clone -b "$branch" --depth 1 "$os_repo" "$target_dir"
    fi

    if [ "$include_gaming" = "1" ] && [ "$os" = "arch" ]; then
        echo "Applying gaming branch on top..."
        git -C "$target_dir" fetch origin gaming
        git -C "$target_dir" checkout gaming -- .
        git -C "$target_dir" add -A
        git -C "$target_dir" commit -m "Apply gaming additions" || true
    fi

    echo "Applying OS-specific configs from $target_dir..."
    yadm alt --global "$target_dir/"
}

main() {
    local os
    os=$(detect_os)
    echo "Detected OS: $os"
    
    local default_branch="main"
    [ "$os" = "arch" ] && default_branch="minimal"
    echo "Branch: ${DOTFILES_BRANCH:-$default_branch}, Gaming: ${DOTFILES_INCLUDE_GAMING:-0}"

    clone_os_repo "$os"
}

main "$@"
