#!/usr/bin/env bash
set -euo pipefail

# Source libs
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../lib" && pwd)"
source "$SCRIPT_DIR/logging"

if command -v fzf &>/dev/null; then
  fzf --zsh > "$HOME/.fzf.zsh"
  log "fzf zsh integration written to ~/.fzf.zsh"
else
  warn "fzf not found, skipping ~/.fzf.zsh generation"
fi
